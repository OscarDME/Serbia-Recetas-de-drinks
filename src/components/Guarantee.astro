---
import { Image } from 'astro:assets';
import { copy } from '../lib/copy.js';
import guaranteeLogo from '../assets/guarantee-logo.webp';
const { guarantee } = copy;
---

<section aria-labelledby="guarantee-title" class="bg-white py-10">
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <div
      class="flex items-center gap-5 rounded-3xl border border-[#b3e6c8] bg-gradient-to-br from-[#f0fff5] to-white p-5 shadow-soft sm:p-6"
    >
      <Image
        src={guaranteeLogo}
        alt={guarantee.title}
        widths={[72, 112, 144]}
        sizes="72px"
        formats={['avif', 'webp']}
        quality={90}
        class="h-20 w-20 shrink-0 object-contain"
      />
      <div>
        <h2 id="guarantee-title" class="text-[15px] font-black text-[#007a30] sm:text-base">
          {guarantee.title}
        </h2>
        <p class="mt-1 text-[12.5px] leading-relaxed text-brand-ink/65 sm:text-[13px]">
          {guarantee.description}
        </p>
      </div>
    </div>
  </div>
</section>
