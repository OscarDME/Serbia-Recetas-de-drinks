---
import { Image } from 'astro:assets';
import { copy } from '../lib/copy.js';
import mockup from '../assets/mockup-produto.webp';

// Doc §7.2 + §13: la URL de checkout es constante en el componente,
// NO va en copy.js. Cada landing puede cambiarla.
const BASE_CHECKOUT_URL_COMPLETE = 'https://www.oriopay.app/p/150-recepata-za-gurmanske-poslastice-u-casi';

const { pricing } = copy;
const { complete, title, sectionId } = pricing;
---

<section
  id={sectionId}
  aria-labelledby="pricing-title"
  class="scroll-mt-20 bg-white py-14"
>
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <h2
      id="pricing-title"
      class="text-center text-[22px] font-black text-brand-ink sm:text-[26px]"
    >
      {title}
    </h2>

    <div class="mt-8 flex justify-center">
      <!-- KIT COMPLETO -->
      <article
        class="relative flex w-full max-w-md flex-col overflow-hidden rounded-3xl border-2 border-brand-green bg-white p-6 shadow-[0_24px_60px_-20px_rgba(0,194,71,0.35)]"
      >
        <span
          class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-green px-4 py-1.5 text-[10.5px] font-extrabold uppercase tracking-[0.18em] text-white shadow-[0_8px_18px_-6px_rgba(0,194,71,0.7)]"
        >
          {complete.badge}
        </span>

        <div class="mx-auto mt-4 w-full max-w-[280px] overflow-hidden rounded-xl">
          <Image
            src={mockup}
            alt={complete.mockupAlt}
            widths={[240, 360, 480, 640]}
            sizes="(min-width: 640px) 280px, 70vw"
            formats={['avif', 'webp']}
            quality={85}
            loading="lazy"
            class="h-auto w-full"
          />
        </div>

        <h3 class="mt-5 text-center text-[18px] font-extrabold text-brand-ink sm:text-[20px]">
          {complete.title}
        </h3>
        <p class="mt-2 text-center text-[13px] leading-relaxed text-brand-ink/60">
          {complete.descriptionLead}{' '}
          <strong class="font-extrabold text-brand-ink">{complete.descriptionStrong}</strong>{' '}
          {complete.descriptionTail}
        </p>

        <p class="mt-5 text-[12.5px] font-bold text-brand-ink">{complete.includesLabel}</p>
        <ul class="mt-2 space-y-2">
          {
            complete.items.map((it) => (
              <li class="flex items-start gap-2 text-[13px] font-semibold text-brand-ink/85">
                <span class="mt-0.5 text-brand-green" aria-hidden="true">
                  ✓
                </span>
                {it}
              </li>
            ))
          }
        </ul>

        <div class="mt-6 text-center">
          <p class="text-[12.5px] text-brand-ink/35 line-through">{complete.strikePrice}</p>
          <p class="font-['Poppins'] text-[54px] font-black leading-none text-brand-green sm:text-[60px]">
            {complete.price}
          </p>
          <p class="mt-1 text-[11.5px] text-brand-ink/55">{complete.priceNote}</p>
        </div>

        <a
          href={BASE_CHECKOUT_URL_COMPLETE}
          data-cta="checkout-complete"
          data-checkout-base={BASE_CHECKOUT_URL_COMPLETE}
          data-offer-price={complete.price}
          class="group relative mt-5 block w-full overflow-hidden rounded-2xl bg-gradient-to-br from-brand-green-light to-brand-green-dark px-5 py-4 text-center text-[15px] font-black uppercase tracking-wide text-white shadow-cta transition-all hover:-translate-y-0.5 hover:shadow-cta-hover focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-green/30"
        >
          <span
            class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent via-white/25 to-transparent -translate-x-full animate-sweep"
            aria-hidden="true"></span>
          <span class="relative">{complete.ctaLabel}</span>
        </a>
        <p class="mt-3 text-center text-[11px] text-brand-ink/55">{complete.footer}</p>
      </article>
    </div>
  </div>
</section>

<script>
  // Doc §13.3: prioridad URL > localStorage
  function getParams() {
    const url = new URL(location.href);
    const src = url.searchParams.get('src') || localStorage.getItem('hotmart_src') || '';
    const fbclid =
      url.searchParams.get('fbclid') || localStorage.getItem('hotmart_fbclid') || '';
    return { src, fbclid };
  }
  function withParams(base) {
    const { src, fbclid } = getParams();
    const u = new URL(base);
    if (src) u.searchParams.set('src', src);
    if (fbclid) u.searchParams.set('fbclid', fbclid);
    return u.toString();
  }

  // Reescribe el href del CTA principal al load y al hacer click
  document.querySelectorAll('a[data-cta="checkout-complete"]').forEach((a) => {
    const base = (a as HTMLAnchorElement).dataset.checkoutBase;
    if (!base) return;
    (a as HTMLAnchorElement).href = withParams(base);
    a.addEventListener('click', () => {
      (a as HTMLAnchorElement).href = withParams(base);
      const price = parseFloat(
        ((a as HTMLAnchorElement).dataset.offerPrice || '0')
          .replace(/[^\d,]/g, '')
          .replace(',', '.'),
      );
      (window as any).dataLayer = (window as any).dataLayer || [];
      (window as any).dataLayer.push({ event: 'begin_checkout', value: price, currency: 'BRL' });
      if (typeof (window as any).fbq === 'function') {
        (window as any).fbq('track', 'InitiateCheckout', { value: price, currency: 'BRL' });
      }
    });
  });
</script>
