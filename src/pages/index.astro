---
import Layout from '../layouts/Layout.astro';
import TimerBar from '../components/TimerBar.astro';
import Hero from '../components/Hero.astro';
import Benefits from '../components/Benefits.astro';
import RecipesCarousel from '../components/RecipesCarousel.astro';
import Bonuses from '../components/Bonuses.astro';
import Pricing from '../components/Pricing.astro';
import Guarantee from '../components/Guarantee.astro';
import FAQ from '../components/FAQ.astro';
import UrgencyBanner from '../components/UrgencyBanner.astro';
import FinalCta from '../components/FinalCta.astro';
import SecurityBadges from '../components/SecurityBadges.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <TimerBar />
  <main id="main">
    <Hero />
    <Benefits />
    <RecipesCarousel />
    <Bonuses />
    <Pricing />
    <Guarantee />
    <FAQ />
    <UrgencyBanner />
    <FinalCta />
    <SecurityBadges />
  </main>
  <Footer />
</Layout>
